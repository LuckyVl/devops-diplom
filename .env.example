# =============================================================================
# YANDEX CLOUD
# =============================================================================
YC_CLOUD_ID=your-cloud-id-here
YC_FOLDER_ID=your-folder-id-here
YC_TOKEN=your-iam-token-or-use-yc-cli
YC_ENDPOINT=https://api.cloud.yandex.net

# =============================================================================
# TERRAFORM BACKEND (заполняется после bootstrap)
# =============================================================================
TF_BACKEND_BUCKET=your-bucket-name
TF_BACKEND_KEY=prod/terraform.tfstate
TF_BACKEND_ACCESS_KEY=your-access-key
TF_BACKEND_SECRET_KEY=your-secret-key

# =============================================================================
# KUBERNETES
# =============================================================================
K8S_CLUSTER_NAME=luckyvl-diploma-k8s
K8S_NAMESPACE=diploma

# =============================================================================
# APPLICATION
# =============================================================================
APP_DOMAIN=app.luckyvl.nip.io
GRAFANA_DOMAIN=grafana.luckyvl.nip.io
GRAFANA_ADMIN_PASSWORD=ChangeMe123!

# =============================================================================
# GITHUB ACTIONS (для локального тестирования)
# =============================================================================
GITHUB_REPOSITORY=LuckyVl/diploma-yandexcloud
GITHUB_REF=refs/heads/main